{
  "manifest_version": 3,
  "name": "SecureCookieGuard",
  "description": "Client-Side Confidentiality Protection for Browser Cookies and Session Storage",
  "version": "1.0",

  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "SecureCookieGuard"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}